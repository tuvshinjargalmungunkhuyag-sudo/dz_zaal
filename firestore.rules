rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /fixed_bookings/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
