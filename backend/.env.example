PORT=3000

# Groq API — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Firebase Admin SDK - Service Account JSON (minified, single line)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Email (Gmail SMTP) — баталгаажуулах код илгээхэд ашиглана
# Gmail: Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_app_password
